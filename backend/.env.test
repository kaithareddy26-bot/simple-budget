# Integration test environment.
# Loaded by tests/integration/conftest.py — never used in production.
# Add .env.test to .gitignore if it contains real secrets.

DATABASE_URL=postgresql://test_user:test_pass@localhost:5433/budget_test

# Test-only secret — safe to commit because it only ever touches the test DB
SECRET_KEY=test-only-secret-32-chars-minimum-xx
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Always create tables when tests start
RUN_DB_INIT=True

# Relax rate limits so integration tests never accidentally hit 429
LOGIN_RATE_LIMIT=1000/minute
REGISTER_RATE_LIMIT=1000/minute
GLOBAL_RATE_LIMIT=10000/minute
REPORT_RATE_LIMIT=1000/minute

RATE_LIMIT_ENABLED=false

# Lockout thresholds — kept low for fast lockout tests
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15

ALLOWED_ORIGINS=["http://localhost:3000"]
# Instructions
# Rename the file and place it at backend/.env. Then run this once to fill in the secret key:
# Run this — copy the output
# python -c "import secrets; print(secrets.token_hex(32))"

# Then open .env and replace REPLACE_WITH_GENERATED_SECRET with that value
# Example of what the line should look like after:
# SECRET_KEY=a3f8c2d19e4b7a6f0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3



DATABASE_URL=postgresql://postgres:budget_pass@db:5432/budget_db
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
RUN_DB_INIT=True
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute
GLOBAL_RATE_LIMIT=60/minute
REPORT_RATE_LIMIT=10/minute
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15
ALLOWED_ORIGINS=["http://localhost:3000","http://frontend:3000","http://localhost:8081"]